# Copy this file to .env and fill in real values. Never commit .env.

# --- Postgres ---
POSTGRES_USER=rag
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rag_knowledge
DATABASE_URL=postgresql+psycopg://rag:changeme@postgres:5432/rag_knowledge

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANSWER_MODEL=claude-sonnet-5

# --- First admin account (created automatically on first startup) ---
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-this-immediately

# --- Auth ---
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Embeddings / reranking ---
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
USE_GPU=true

# --- Retrieval tuning ---
TOP_K_RETRIEVE=100
TOP_K_RERANKED=30
CHUNK_SIZE_CHARS=1500
CHUNK_OVERLAP_CHARS=200
